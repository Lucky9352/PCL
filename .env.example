# ═══════════════════════════════════════════════════
# IndiaGround — Environment Configuration
# ═══════════════════════════════════════════════════
# Copy to .env and fill in values:  cp .env.example .env

# Frontend
VITE_API_URL=http://localhost:8000

# FastAPI / Backend
APP_ENV=development
DEBUG=1
SECRET_KEY=change-me-generate-with-openssl-rand-base64-64

# Database (PostgreSQL)
# Local docker-compose PostgreSQL:
DATABASE_URL=postgresql+asyncpg://indiaground:indiaground@localhost:5432/indiaground

# Sync URL for Alembic migrations:
DATABASE_URL_SYNC=postgresql://indiaground:indiaground@localhost:5432/indiaground

# Redis / Celery
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Google Fact Check Tools API (optional — enriches claim verification)
GOOGLE_FACTCHECK_API_KEY=

# NewsAPI.org (optional — enables multi-source scraping, free tier: 100 req/day)
# Get key at: https://newsapi.org/register
NEWSAPI_KEY=

# Scraper
# Scrape interval in minutes (default: 30)
SCRAPE_INTERVAL_MINUTES=30

# ML / NLP
# Device override: auto | cpu | cuda | mps
# "auto" detects best available (CUDA GPU > Apple MPS > CPU)
ML_DEVICE=auto

# HuggingFace (optional)
# HF_TOKEN=          # Set for private models or higher Hub rate limits
# HF_HOME=/path/to/cache  # Cache dir, defaults to ~/.cache/huggingface
